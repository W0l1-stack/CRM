# PostgreSQL connection string (pgx/v5). Required.
DATABASE_URL=postgres://crm_user:crm_password_dev@localhost:5432/crm_db?sslmode=disable
# Redis connection string (used by the Node real-time service / future rate limiting).
REDIS_URL=redis://localhost:6379
# Secret used to sign JWT access tokens. Required. Use a long random value in prod.
JWT_SECRET=dev_jwt_secret_change_in_production
# HTTP port the Go API listens on.
PORT=3001
# Public URL of the React app, used for Stripe success/cancel redirects.
FRONTEND_URL=http://localhost:3000

# Outbound integrations (not required to boot).
RESEND_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Billing (Stripe). Without these, billing endpoints return 503 (the app still runs).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Recurring Price IDs created in the Stripe dashboard for each plan.
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
