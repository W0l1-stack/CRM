# PostgreSQL connection string (pgx/v5). Required.
DATABASE_URL=postgres://crm_user:crm_password_dev@localhost:5432/crm_db?sslmode=disable
# Redis connection string (used by the Node real-time service / future rate limiting).
REDIS_URL=redis://localhost:6379
# Secret used to sign JWT access tokens. Required. Use a long random value in prod.
JWT_SECRET=dev_jwt_secret_change_in_production
# Stable key for encrypting account integration credentials at rest. Set this in
# production BEFORE any customer connects a provider, so rotating JWT_SECRET never
# locks saved credentials. Must match backend-node. Falls back to JWT_SECRET if empty.
INTEGRATIONS_ENC_KEY=
# HTTP port the Go API listens on.
PORT=3001
# Public URL of the React app, used for Stripe success/cancel redirects.
FRONTEND_URL=http://localhost:3000

# Error tracking (optional). Set to your Sentry DSN to enable.
SENTRY_DSN=

# Google Calendar OAuth (optional — Calendar "Connect" shows "Not configured" without these).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:3001/api/v1/integrations/google/callback

# Outbound integrations (not required to boot).
RESEND_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Billing (Stripe). Without these, billing endpoints return 503 (the app still runs).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Recurring Price IDs created in the Stripe dashboard for each plan.
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
