# PostgreSQL (same database the Go API owns). Required.
DATABASE_URL=postgres://crm_user:crm_password_dev@localhost:5432/crm_db?sslmode=disable
# Redis for Socket.io fan-out + BullMQ. Required.
REDIS_URL=redis://localhost:6379
# Must match the Go API's JWT secret (used to authenticate socket connections). Required.
JWT_SECRET=dev_jwt_secret_change_in_production
# Must match the Go API's INTEGRATIONS_ENC_KEY (used to decrypt provider creds).
# Falls back to JWT_SECRET if empty.
INTEGRATIONS_ENC_KEY=
PORT=3002

# Public base URL of this service (used to validate Twilio webhook signatures).
PUBLIC_URL=

# Error tracking (optional). Set to your Sentry DSN to enable.
SENTRY_DSN=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev

# SMS (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
