# Base URL of the Go API (includes the /api/v1 prefix).
# Local dev against the Go service directly:
VITE_API_URL=http://localhost:3001/api/v1
# Through the nginx gateway instead, use: http://localhost:8080/api/v1

# Node real-time (Socket.io) service base URL (used in Week 5-6).
VITE_SOCKET_URL=http://localhost:3002
